---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="00_GEEKSCAT CONF 2026" description="La conferència de geeks per a geeks de Catalunya. 2026.">
  <main class="pt-16 min-h-dvh flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 grid-lines opacity-20 pointer-events-none"></div>
    <div class="text-center relative z-10 px-6">
      <span class="font-mono text-code-sm text-primary-container uppercase tracking-widest block mb-4">
        [ INIT_SYSTEM_ROOT ]
      </span>
      <p class="font-display text-headline-md text-on-surface uppercase tracking-tighter terminal-cursor">
        CARREGANT_GEEKSCAT_CONF
      </p>
    </div>
  </main>
</BaseLayout>
