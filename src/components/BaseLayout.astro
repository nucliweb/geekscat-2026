---
import '../styles/global.css';
import Nav from './Nav.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description = 'La conferència de geeks per a geeks de Catalunya.',
  canonical,
  ogImage,
} = Astro.props;

const siteUrl = 'https://conf.geeks.cat';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title === '00_GEEKSCAT CONF 2026' ? title : `${title} · GEEKSCAT CONF 2026`;
---

<!doctype html>
<html lang={Astro.currentLocale ?? 'ca'} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Anti-FOUC: apply theme before first paint -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        var m = matchMedia('(prefers-color-scheme:light)').matches ? 'light' : 'dark';
        document.documentElement.dataset.theme = t || m;
      })();
    </script>

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={`${siteUrl}${ogImage}`} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preload critical font (Space Grotesk variable, used in headings/nav) -->
    <link
      rel="preload"
      href="/fonts/space-grotesk-latin-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary-container focus:text-on-primary focus:font-mono focus:text-code-sm">
      Saltar al contingut principal
    </a>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
