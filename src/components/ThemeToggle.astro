---
import Icon from './Icon.astro';
---

<button
  data-theme-toggle
  aria-label="Toggle theme"
  class="p-2 text-on-surface-variant hover:text-primary-container transition-colors duration-150 cursor-pointer flex items-center"
>
  <span class="icon-sun"><Icon name="sun" size={18} /></span>
  <span class="icon-moon"><Icon name="moon" size={18} /></span>
</button>

<script>
  document.addEventListener('click', (e) => {
    if ((e.target as Element).closest('[data-theme-toggle]')) {
      const html = document.documentElement;
      const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
      html.dataset.theme = next;
      localStorage.setItem('theme', next);
    }
  });
</script>
